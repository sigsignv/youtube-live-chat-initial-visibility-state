root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.css]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{ts,tsx}]
indent_style = space
indent_size = 2

[biome.jsonc]
indent_style = tab
indent_size = 2

[devcontainer.json]
indent_style = tab
indent_size = 2
